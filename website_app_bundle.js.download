"instagram.dialog.legal.terms":"Regulaminowi","instagram.dialog.legal.and":"oraz","instagram.dialog.legal.privacy":"Zasadom ochrony prywatno\u015bci","instagram.dialog.legal.suffix":"Instagrama."},ro:{"url.rights_disclaimer.prefix":"Asigur\u0103-te c\u0103 de\u021bii toate","url.rights_disclaimer.link":"drepturile necesare","url.rights_disclaimer.suffix":"asupra con\u021binutului pe care \u00eel oferi.","upload_disclaimer.body.prefix":"Dac\u0103 folose\u0219ti aceast\u0103 func\u021bie, confirmi c\u0103 de\u021bii",
