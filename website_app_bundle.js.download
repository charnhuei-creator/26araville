"tos.and":"\ubc0f","button.agree":"\ub3d9\uc758 \ubc0f \uacc4\uc18d","button.exit":"\ub098\uac00\uae30","privacy.title":"Pomelli \uac1c\uc778\uc815\ubcf4\ucc98\ub9ac\ubc29\uce68","privacy.intro":"\ubcf8 \uc54c\ub9bc\uacfc \uc790\uc0ac\uc758","privacy.policy_link":"\uac1c\uc778\uc815\ubcf4\ucc98\ub9ac\ubc29\uce68","privacy.intro_end":"\uc740 Pomelli\uac00 \uc0ac\uc6a9\uc790\uc758 \ub370\uc774\ud130\ub97c \ucc98\ub9ac\ud558\ub294 \ubc29\ubc95\uc744 \uc124\uba85\ud569\ub2c8\ub2e4. \uc8fc\uc758 \uae4a\uac8c \uc77d\uc5b4\uc8fc\uc2dc\uae30 \ubc14\ub78d\ub2c8\ub2e4.",
"privacy.collection":"\uc0ac\uc6a9\uc790\uac00 Pomelli\ub97c \uc0ac\uc6a9\ud560 \ub54c Google\uc740 \uc0ac\uc6a9\uc790\uc758 \ube44\uc988\ub2c8\uc2a4 DNA(\uc0ac\uc6a9\uc790\uc758 \ub85c\uace0, \ube0c\ub79c\ub4dc \uc0c9\uc0c1, \uc11c\uccb4, \uc774\ubbf8\uc9c0 \ud3ec\ud568) \ubc0f \ucea0\ud398\uc778 \ub370\uc774\ud130(\ubaa8\ub4e0 \ud504\ub86c\ud504\ud2b8, \uc0ac\uc6a9\uc790\uac00 \uc0dd\uc131\ud55c \ucf58\ud150\uce20 \ud3ec\ud568), \uae30\ub2a5 \uc0ac\uc6a9 \uc815\ubcf4, \uc0ac\uc6a9\uc790\uc758 \uc758\uacac\uc744 \uc218\uc9d1\ud569\ub2c8\ub2e4. Google\uc740 \uc774 \ub370\uc774\ud130\ub97c Google \uc81c\ud488 \ubc0f \uc11c\ube44\uc2a4, \uc0dd\uc131\ud615 AI \ubaa8\ub378\uc744 \uc81c\uacf5, \uac1c\uc120, \uac1c\ubc1c\ud558\uae30 \uc704\ud55c \ubaa9\uc801\uc744 \ud3ec\ud568\ud574 Google",
"privacy.collection_end":"\uacfc \uc0ac\uc6a9\uc790\uc758 Pomelli \uc124\uc815\uc5d0 \ub530\ub77c \uc0ac\uc6a9\ud569\ub2c8\ub2e4. \uc0ac\uc6a9\uc790 \ub370\uc774\ud130 \uc0ad\uc81c\ub97c \uc694\uccad\ud558\ub824\uba74 pomelli-help@google.com\uc73c\ub85c \uc774\uba54\uc77c\uc744 \ubcf4\ub0b4\uc8fc\uc138\uc694.","privacy.protection":"\ubcf8\uc0ac\ub294 \uc0ac\uc6a9\uc790\uc758 \uac1c\uc778 \uc815\ubcf4\ub97c \ubcf4\ud638\ud558\uae30 \uc704\ud55c \uc870\uce58\ub97c \ucde8\ud569\ub2c8\ub2e4. Pomelli \ub370\uc774\ud130\uc758 \uc784\uc758 \uc0d8\ud50c\uc774 \ubaa8\ub378 \uac1c\uc120\uc744 \uc704\ud574 \uc11c\ube44\uc2a4 \uc81c\uacf5\uc5c5\uccb4\uc758 \uc219\ub828\ub41c \uac80\ud1a0\uc790\ub97c \ube44\ub86f\ud55c \uc778\uac04\uc5d0 \uc758\ud574 \uac80\ud1a0\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc0ac\uc6a9\uc790\uc758 \ub370\uc774\ud130\uac00 \uc774 \uc0d8\ud50c\uc5d0 \ud3ec\ud568\ub41c \uacbd\uc6b0, \uc774 \ub370\uc774\ud130\ub294 \uc0ac\uc6a9\uc790\uc758 Google \uacc4\uc815\uacfc \ubd84\ub9ac\ub418\uba70 \uc0ac\uc6a9\uc790\uc5d0\uac8c \ub2e4\uc2dc \uc5f0\uacb0\ub418\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. Google\uc740 \uc775\uba85\ud654\ub41c \uc774 \uc0d8\ud50c\uacfc \uad00\ub828 \ub370\uc774\ud130\ub97c \uc0ac\uc6a9\uc790\uac00 \uc0ad\uc81c\ud558\uac70\ub098 \uc774 \uc124\uc815\uc744 \ucd94\ud6c4\uc5d0 \ub044\ub294 \uacbd\uc6b0\uc5d0\ub3c4 \ucd5c\uc7a5 3\ub144\uae4c\uc9c0 \ubcf4\uad00\ud569\ub2c8\ub2e4. \uac80\ud1a0\uc790\uac00 \ubcf4\uae30\ub97c \uc6d0\ud558\uc9c0 \uc54a\uac70\ub098 Google\uc774 Google AI\ub97c \uac1c\uc120\ud558\uae30 \uc704\ud574 \uc0ac\uc6a9\ud558\uae30\ub97c \uc6d0\ud558\uc9c0 \uc54a\ub294 \uae30\ubc00 \uc815\ubcf4\ub97c \uc785\ub825\ud558\uc9c0 \ub9c8\uc2ed\uc2dc\uc624.",
"privacy.control":"\uc0ac\uc6a9\uc790\uac00 \ub370\uc774\ud130\ub97c \ud1b5\uc81c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud5a5\ud6c4 Pomelli \ucf58\ud150\uce20(\uc608. \ube44\uc988\ub2c8\uc2a4 DNA, \ucea0\ud398\uc778 \ub370\uc774\ud130)\uac00 \uc790\uc0ac\uc758 \uc0dd\uc131\ud615 AI \ubaa8\ub378 \ud559\uc2b5\uc5d0 \uc4f0\uc774\uae30\ub97c \uc6d0\ud558\uc9c0 \uc54a\ub294\ub2e4\uba74 \uc5b8\uc81c\ub4e0\uc9c0 Pomelli \uc124\uc815\uc5d0\uc11c \uc120\ud0dd \ud574\uc81c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc758\uacac\uc744 \uc81c\uacf5\ud558\uae30\ub85c \uc120\ud0dd\ud55c \uacbd\uc6b0, Google\uc740 \uc0ac\uc6a9\uc790\uac00 \uc120\ud0dd \ud574\uc81c\ud55c \uacbd\uc6b0\uc5d0\ub3c4 \uc774 \uc758\uacac\uacfc \uad00\ub828 \ucf58\ud150\uce20\ub97c \uc790\uc0ac\uc758 \uc0dd\uc131\ud615 AI \ubaa8\ub378 \ud559\uc2b5\uc744 \uc704\ud574 \uc0ac\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.",
"privacy.terms_notice":"\uc0ac\uc6a9\uc790\uc758 Pomelli \uc124\uc815\uc740 \uc0ac\uc6a9\uc790\uc758 \ub370\uc774\ud130\uac00 \uc11c\ube44\uc2a4 \uc81c\uacf5 \ubc0f","privacy.google_tos":"Google \uc57d\uad00","privacy.prohibited_policy":"\uae08\uc9c0\ub41c \uc0ac\uc6a9 \uc815\ucc45","privacy.terms_notice_tail":"\uc758 \uc704\ubc18, \uc0ac\uae30, \uc545\uc6a9\uc744 \ub354 \uc798 \uac10\uc9c0\ud558\uace0 \ub300\uc751\ud558\uae30 \uc704\ud574 \ucc98\ub9ac\ub418\ub294 \uac83\uc744 \ud1b5\uc81c\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.",
"privacy.last_updated":"\ucd5c\uc2e0 \uc5c5\ub370\uc774\ud2b8: 25\ub144 6\uc6d4 11\uc77c","settings.title":"\uacc4\uc815 \uc124\uc815","settings.subtitle":"\uacc4\uc815 \uc124\uc815 \ubcf4\uae30 \ubc0f \ud3b8\uc9d1\ud558\uae30","settings.help_title":"Pomelli \uac1c\uc120\uc744 \ub3c4\uc640\uc8fc\uc138\uc694","settings.help_on":"\uc0ac\uc6a9\uc790\uc758 \ub370\uc774\ud130(\ube44\uc988\ub2c8\uc2a4 DNA \ubc0f \ucea0\ud398\uc778 \ub370\uc774\ud130 \ud3ec\ud568)\ub85c Google\uc758 \uc0dd\uc131\ud615 AI \ubaa8\ub378\uc744 \ud6c8\ub828\ud560 \uc218 \uc788\ub3c4\ub85d \ud5c8\uc6a9\ud574 \uc8fc\uc138\uc694. \uc774\ub807\uac8c \ud558\uba74 Pomelli\ub97c \uc0ac\uc6a9\uc790\ubfd0 \uc544\ub2c8\ub77c \ubaa8\ub4e0 \uc0ac\ub78c\uc744 \uc704\ud574 \uac1c\uc120\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc790\uc0ac\ub294 \uc0ac\uc6a9\uc790\uc758 \uac1c\uc778 \uc815\ubcf4\ub97c \ubcf4\ud638\ud558\uae30 \uc704\ud55c \uc870\uce58\ub97c \ucde8\ud569\ub2c8\ub2e4.",
"settings.learn_more":"\uc790\uc138\ud788 \uc54c\uc544\ubcf4\uae30","settings.help_on_tail":"\uc774 \uc124\uc815\uc774 \uaebc\uc838 \uc788\uc5b4\ub3c4 \uc0ac\uc6a9\uc790\uc758 \ub370\uc774\ud130\ub294","settings.help_off":"\uc0ac\uc6a9\uc790\uc758 \ud5a5\ud6c4 \ub370\uc774\ud130\ub294 \uc0ac\uc6a9\uc790\uac00 \uc758\uacac\uc744 \ubcf4\ub0b8 \uacbd\uc6b0\ub97c \uc81c\uc678\ud558\uace0 Google\uc758 \uc0dd\uc131\ud615 AI \ubaa8\ub378 \uac1c\uc120\uc744 \uc704\ud574 \uc0ac\uc6a9\ub418\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uc775\uba85\ud654\ub418\uc5b4 \uc0ac\ub78c\uc774 \uac80\ud1a0\ud55c \uc0d8\ud50c \ub370\uc774\ud130\ub294 \uc0ac\uc6a9\uc790\uac00 \uc0ad\uc81c\ud558\ub294 \uacbd\uc6b0\uc5d0\ub3c4 \ucd5c\uc7a5 3\ub144\uae4c\uc9c0 \uc800\uc7a5\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.",
"settings.help_off_tail":"\uc774 \uc124\uc815\uc774 \uaebc\uc838 \uc788\uc5b4\ub3c4 \uc0ac\uc6a9\uc790\uc758 \ub370\uc774\ud130\ub294",disclaimer:"Pomelli\ub294 \uc2e4\uc218\ub97c \ud560 \uc218 \uc788\uc73c\ub2c8 \uaf2d \ub2e4\uc2dc \ud655\uc778\ud558\uc138\uc694.",sample_businesses:"\uc77c\ubc18\uc801\uc778 \ud5c8\uad6c\uc758 \uc774\ub984\uc744 \uac00\uc9c4 AI \uc0dd\uc131 \uc0d8\ud50c \ube44\uc988\ub2c8\uc2a4\ub4e4\uc785\ub2c8\ub2e4. \ucd5c\uc885 \ucd9c\ub825\uc758 \uc815\ud655\uc131\uacfc \uc801\ubc95\uc131\uc744 \ud655\uc778\ud558\ub294 \uac83\uc740 \uc0ac\uc6a9\uc790\uc758 \ucc45\uc784\uc785\ub2c8\ub2e4.",
"marketing.title":"\ucd5c\uc2e0 \uc18c\uc2dd\uc744 \ubc1b\uc544\ubcf4\uc138\uc694","marketing.subtitle":"\ub2e4\uc74c \ud56d\ubaa9\uc5d0 \ub3d9\uc758\ud558\uc5ec \uc11c\ube44\uc2a4 \ud658\uacbd\uc744 \uac1c\uc120\ud558\ub294 \ub370 \ub3d9\ucc38\ud574 \uc8fc\uc138\uc694.","marketing.email_optin":"Pomelli\uc758 \uc5c5\ub370\uc774\ud2b8, \ud61c\ud0dd, \uc720\uc6a9\ud55c \ud301 \ubc0f \uc18c\uc2dd\uc744 \uc774\uba54\uc77c\ub85c \ubc1b\uaca0\uc2b5\ub2c8\ub2e4.","marketing.uxr_optin":"\ud5a5\ud6c4 \uc9c4\ud589\ub420 Pomelli\uc758 \uc5f0\uad6c\uc5d0 \ucc38\uc5ec \uc81c\uc548\uc744 \ubc1b\uace0 \uc2f6\uc2b5\ub2c8\ub2e4.",
"marketing.confirm":"\ud655\uc778","marketing.comm_prefs":"\ucee4\ubba4\ub2c8\ucf00\uc774\uc158 \ud658\uacbd\uc124\uc815","website.publish.rights_disclaimer":"\uac8c\uc2dc\ud558\uae30 \uc804\uc5d0, \uc774 \uc0ac\uc774\ud2b8\uc5d0 \uc81c\uacf5\ub41c \ubaa8\ub4e0 \ucf58\ud150\uce20\uc5d0 \ub300\ud55c \ud544\uc694\ud55c \ubaa8\ub4e0 \uad8c\ud55c\uc774 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.","website.publish.replace_live_warning":"\uac8c\uc2dc\ud558\uba74 \ud604\uc7ac \ub77c\uc774\ube0c \ubc84\uc804\uc744 \ub300\uccb4\ud569\ub2c8\ub2e4. \uac8c\uc2dc\ud558\uae30 \uc804\uc5d0, \uc774 \uc0ac\uc774\ud2b8\uc5d0 \uc81c\uacf5\ub41c \ubaa8\ub4e0 \ucf58\ud150\uce20\uc5d0 \ub300\ud55c \ud544\uc694\ud55c \ubaa8\ub4e0 \uad8c\ud55c\uc774 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694.",
"website.report_legal_issue":"\ubc95\uc801 \ubb38\uc81c \uc2e0\uace0\ud558\uae30","instagram.dialog.legal.prefix":"\ucf58\ud150\uce20\ub97c Instagram\uc5d0 \uac8c\uc2dc\ud558\uba74, \uc5c5\ub85c\ub4dc\ud55c \ucf58\ud150\uce20\uc5d0 \ub300\ud574 \ud544\uc694\ud55c \ubaa8\ub4e0 \uad8c\ud55c\uc774 \uc788\uc74c\uc744 \ud655\uc778\ud558\ub294 \uac83\uc785\ub2c8\ub2e4. Instagram\uc758","instagram.dialog.legal.terms":"\uc57d\uad00","instagram.dialog.legal.and":"\uacfc","instagram.dialog.legal.privacy":"\uac1c\uc778\uc815\ubcf4\ucc98\ub9ac\ubc29\uce68",
"instagram.dialog.legal.suffix":"\uc774 \uac8c\uc2dc\ud558\ub294 \ubaa8\ub4e0 \ucf58\ud150\uce20\uc5d0 \uc801\uc6a9\ub429\ub2c8\ub2e4."},"pt-BR":{"tos.title":"Informa\u00e7\u00f5es importantes","tos.google_terms":"Termos","tos.use_policy":"Pol\u00edtica de Uso","tos.apply":"do Google se aplicam ao seu uso do Pomelli.","tos.privacy_notice":"O Aviso de Privacidade","tos.privacy_desc":"descreve como seus dados s\u00e3o tratados.","tos.data_usage":"Os dados que voc\u00ea envia e gera no Pomelli podem ser analisados e usados para melhorar a IA do Google.",
"tos.manage_settings":"Gerencie suas configura\u00e7\u00f5es de treinamento.","tos.and":"e","button.agree":"Concordar e continuar","button.exit":"Sair","privacy.title":"Aviso de Privacidade do Pomelli","privacy.intro":"Este aviso e nossa","privacy.policy_link":"Pol\u00edtica de Privacidade","privacy.intro_end":"descrevem como o Pomelli trata seus dados. Leia com aten\u00e7\u00e3o.","privacy.collection":"Quando voc\u00ea usa o Pomelli, o Google coleta a identidade da sua marca (incluindo logotipo, cores, tipografia e imagens) e os dados da sua campanha (incluindo comandos e conte\u00fados que voc\u00ea gerar), informa\u00e7\u00f5es sobre uso e seu feedback. O Google usa esses dados de acordo com nossa",
"privacy.collection_end":"e suas configura\u00e7\u00f5es do Pomelli, inclusive para fornecer, aprimorar e desenvolver produtos e servi\u00e7os do Google e modelos de IA generativa. Para solicitar a exclus\u00e3o dos seus dados de usu\u00e1rio, envie um e-mail para pomelli-help@google.com.","privacy.protection":"Adotamos medidas para proteger sua privacidade. Uma amostra aleat\u00f3ria de dados do Pomelli pode ser analisada por pessoas (incluindo revisores treinados de nossos prestadores de servi\u00e7os) para ajudar a melhorar nossos modelos. Se os seus dados fizerem parte dessa amostra, eles ser\u00e3o separados da sua Conta do Google e n\u00e3o ser\u00e3o vinculados a voc\u00ea. O Google mant\u00e9m essas amostras desidentificadas e os dados relacionados por at\u00e9 tr\u00eas anos, mesmo que voc\u00ea os exclua ou desative essa configura\u00e7\u00e3o posteriormente. N\u00e3o insira informa\u00e7\u00f5es confidenciais que voc\u00ea n\u00e3o gostaria que um revisor humano visse ou que o Google usasse para aprimorar a IA no Google.",
"privacy.control":"Voc\u00ea est\u00e1 no controle. Se n\u00e3o quiser que seu conte\u00fado futuro no Pomelli (por exemplo, identidade da marca e dados de campanha) seja usado para treinar nossos modelos de IA generativa, voc\u00ea pode desativar essa op\u00e7\u00e3o nas configura\u00e7\u00f5es do Pomelli a qualquer momento. Se optar por enviar feedback, o Google poder\u00e1 usar esse feedback e qualquer conte\u00fado associado para treinar nossos modelos de IA generativa, mesmo que voc\u00ea tenha desativado essa op\u00e7\u00e3o.",
"privacy.terms_notice":"Suas configura\u00e7\u00f5es do Pomelli tamb\u00e9m n\u00e3o controlam o tratamento dos seus dados para fornecer o servi\u00e7o nem para detectar e responder melhor a fraudes, abusos e viola\u00e7\u00f5es dos","privacy.google_tos":"Termos de Servi\u00e7o","privacy.prohibited_policy":"Pol\u00edtica de Uso Proibido do Google","privacy.terms_notice_tail":".","privacy.last_updated":"\u00daltima atualiza\u00e7\u00e3o: 11/06/25","settings.title":"Configura\u00e7\u00f5es da conta",
"settings.subtitle":"Veja e edite as configura\u00e7\u00f5es da sua conta","settings.help_title":"Ajude a melhorar o Pomelli para todos","settings.help_on":"Permita que seus dados (incluindo a identidade da sua marca e dados de campanha) sejam usados para treinar os modelos de IA generativa do Google, o que ajuda a melhorar o Pomelli para voc\u00ea e para todos que o usam. Tomamos medidas para proteger sua privacidade.","settings.learn_more":"Saiba mais","settings.help_on_tail":"Quando essa configura\u00e7\u00e3o estiver desativada, seus dados ainda poder\u00e3o ser usados para detectar e responder melhor a fraudes, abusos e viola\u00e7\u00f5es dos",
"settings.help_off":"Seus dados futuros n\u00e3o ser\u00e3o usados para melhorar os modelos de IA generativa do Google, exceto se voc\u00ea enviar feedback. Amostras desidentificadas que j\u00e1 tenham sido analisadas por revisores humanos s\u00e3o mantidas por at\u00e9 tr\u00eas anos, mesmo que voc\u00ea as exclua.","settings.help_off_tail":"Quando essa configura\u00e7\u00e3o estiver desativada, seus dados ainda poder\u00e3o ser usados para detectar e responder melhor a fraudes, abusos e viola\u00e7\u00f5es dos",
disclaimer:"O Pomelli pode cometer erros. Por isso, cheque as respostas.",sample_businesses:"Estes s\u00e3o exemplos de empresas gerados por IA, com nomes comerciais fict\u00edcios e gen\u00e9ricos. Voc\u00ea \u00e9 respons\u00e1vel por verificar a exatid\u00e3o e a conformidade legal de qualquer conte\u00fado final.","marketing.title":"Fique por dentro","marketing.subtitle":"Ajude a melhorar sua experi\u00eancia marcando as op\u00e7\u00f5es abaixo:","marketing.email_optin":"Quero receber e-mails com atualiza\u00e7\u00f5es, ofertas, dicas \u00fateis e novidades sobre o Pomelli",
"marketing.uxr_optin":"Tenho interesse em receber convites para futuras pesquisas do Pomelli","marketing.confirm":"Confirmar","marketing.comm_prefs":"Prefer\u00eancias de comunica\u00e7\u00e3o","website.publish.rights_disclaimer":"Antes de publicar, verifique se voc\u00ea possui os direitos necess\u00e1rios para todo o conte\u00fado fornecido neste site.","website.publish.replace_live_warning":"A publica\u00e7\u00e3o substituir\u00e1 a vers\u00e3o atual. Antes de publica\u00e7\u00e3o, verifique se voc\u00ea possui os direitos necess\u00e1rios para todo o conte\u00fado fornecido neste site.",
"website.report_legal_issue":"Denunciar problema legal","instagram.dialog.legal.prefix":"Ao publicar conte\u00fado no Instagram, voc\u00ea confirma que possui todos os direitos necess\u00e1rios sobre o conte\u00fado que voc\u00ea carrega. Os","instagram.dialog.legal.terms":"Termos","instagram.dialog.legal.and":"e a","instagram.dialog.legal.privacy":"Pol\u00edtica de Privacidade","instagram.dialog.legal.suffix":"do Instagram se aplicam a qualquer conte\u00fado que voc\u00ea publicar."},sw:{"tos.title":"Mambo ya Kufahamu",
"tos.google_terms":"Sheria na Masharti","tos.use_policy":"Sera ya Matumizi","tos.apply":"ya Google hutumika unapotumia Pomelli.","tos.privacy_notice":"Ilani ya Faragha","tos.privacy_desc":"inafafanua jinsi data yako inavyoshughulikiwa.","tos.data_usage":"Data unayopakia na kutayarisha kwenye Pomelli yawezakukaguliwa na kutumiwa kuboresha Google AI.","tos.manage_settings":"Dhibiti mipangilio yako ya mafunzo.","tos.and":"na","button.agree":"Kubali na uendelee","button.exit":"Toka","privacy.title":"Ilani ya Faragha ya Pomelli",
"privacy.intro":"Ilani hii na","privacy.policy_link":"Sera yetu ya Faragha","privacy.intro_end":"hufananua jinsi Pomelli inavyoshughulikia data yako. Tafadhali zisome kwa umakini.","privacy.collection":"Unapotumia Pomelli, Google hukusanya maelezo kuhusu biashara yako (ikijumuisha nembo, rangi za chapa, taipografia na picha zako) na data yako ya kampeni (ikiwemo vidokezo na maudhui unayotayarisha), maelezo kuhusu matumizi ya vipengele na maoni yako. Google hutumia data hii kwa mujibu wa","privacy.collection_end":"Sera yetu ya Faragha na mipangilio yako ya Pomelli ili kutoa, kuboresha na kubuni bidhaa na huduma za Google na kuandaa mifumo ya AI zalishi. Kuomba kufutwa kwa data yako ya mtumiaji, tuma barua pepe kwa pomelli-help@google.com.",
"privacy.protection":"Tunachukua hatua kulinda faragha yako. Sampuli nasibu ya data ya Pomelli yawezakuhakikiwa na binadamu (wakiwemo wahakiki wenye mafunzo kutoka kwa watoa huduma wetu) ili kusaidia kuboresha mifumo yetu. Data yako ni sehemu ya sampuli hii, itatengwa na Akaunti yako ya Google na haitahusishwa nawe. Google huhifadhi sampuli hizi zisizotambulisha mtu na data inayohusika kwa hadi miaka mitatu, hata ukifuta data yako au uzime mipangilio hii baadaye. Tafadhali usiweke taarifa za siri ambazo hungependa mhakiki azione au Google kutumia ili kuboresha Google AI.",
"privacy.control":"Udhibiti ni wako. Ikiwa hungependa maudhui yajayo ya Pomelli (k.m. maelezo ya biashara na data ya kampeni) yatumike kufunza mifumo yetu ya AI zalishi, unaweza kujiondoa katika mipangilio ya Pomelli wakati wowote. Ukiamua kutoa maoni, Google inaweza kutumia maoni hayo na maudhui yoyote yanayohusiana kufunza mifumo yetu ya AI zalishi hata ikiwa umechagua kujiondoa.","privacy.terms_notice":"Mipangilio yako ya Pomelli pia haisimamii uchakataji wa data yako ili kutoa huduma na kubaini vyema zaidi na kushughulikia ulaghai, matumizi mabaya na ukiukaji wa",
"privacy.google_tos":"Sheria na Masharti ya Google","privacy.prohibited_policy":"Sera Dhidi ya Matumizi Yasiyokubalika","privacy.terms_notice_tail":".","privacy.last_updated":"Mara ya mwisho kusasishwa: 06/11/25","settings.title":"Mipangilio ya Akaunti","settings.subtitle":"Angalia na ubadilishe mipangilio yako ya akaunti","settings.help_title":"Saidia kuboresha Pomelli kwa kila mtu","settings.help_on":"Ruhusu data yako (ikiwemo maelezo ya biashara yako na data ya kampeni) itumiwe kufundisha mifumo ya AI zalishi ya Google, inayoboresha Pomelli kwako na kwa wote wanaoitumia. Tunachukua hatua kulinda faragha yako.",
"settings.learn_more":"Pata maelezo zaidi","settings.help_on_tail":"Wakati mipangilio hii imezimwa, data yako bado inaweza kutumiwa kutambua vyema zaidi na kushughulikia ulaghai, matumizi mabaya na ukiukaji wa","settings.help_off":"Data yako ya baadaye haitatumiwa kuboresha mifumo ya AI zalishi ya Google, isipokuwa ikiwa utatuma maoni. Sampuli zisizotambulisha mtu ambazo tayari zimehakikiwa na wahakiki binadamu huhifadhiwa kwa hadi miaka mitatu, hata ukifuta data hiyo.","settings.help_off_tail":"Wakati mipangilio hii imezimwa, data yako bado inaweza kutumiwa kutambua vyema zaidi na kushughulikia ulaghai, matumizi mabaya na ukiukaji wa",
disclaimer:"Pomelli yawezakukosea kwa hivyo thibitisha majibu yake.",sample_businesses:"Hizi ni kampuni za mfano zilizotayarishwa na AI zenye majina ya biashara ya kubuniwa. Una wajibu wa kuthibitisha uhakika na uhalali wa matokeo yoyote.","marketing.title":"Endelea kupokea Arifa","marketing.subtitle":"Tusaidie kuboresha hali yako ya utumiaji kwa kujiunga na yafuatayo:","marketing.email_optin":"Ningependa kupokea barua pepe za arifa, ofa, vidokezo muhimu na habari kuhusu Pomelli","marketing.uxr_optin":"Ningependa kualikwa kwenye utafiti ujao wa Pomelli",
"marketing.confirm":"Thibitisha","marketing.comm_prefs":"Mapendeleo ya mawasiliano","website.publish.rights_disclaimer":"Kabla ya kuchapisha, hakikisha kuwa una haki zinazofaa za maudhui yote kwenye tovuti hii","website.publish.replace_live_warning":"Kuchapisha maudhui haya kutachukua nafasi ya maudhui ya sasa yanayotumika. Kabla ya kuchapisha, hakikisha kuwa una haki zinazofaa za maudhui yote kwenye tovuti hii.","website.report_legal_issue":"Ripoti tatizo la kisheria","instagram.dialog.legal.prefix":"Kwa kuchapisha maudhui kwenye Instagram, unathibitisha kuwa una haki zote zinazofaa za maudhui unayopakia.",
"instagram.dialog.legal.terms":"Sheria na Masharti","instagram.dialog.legal.and":"na","instagram.dialog.legal.privacy":"Sera ya Faragha","instagram.dialog.legal.suffix":"ya Instagram zinatumika kwenye maudhui yoyote unayochapisha."},tr:{"tos.title":"Bilinmesi Gerekenler","tos.google_terms":"Google \u015eartlar\u0131'na","tos.use_policy":"Kullan\u0131m Politikas\u0131'na","tos.apply":"tabidir.","tos.privacy_notice":"Gizlilik Uyar\u0131s\u0131'nda","tos.privacy_desc":"verilerinizin nas\u0131l kullan\u0131ld\u0131\u011f\u0131 a\u00e7\u0131klan\u0131r.",
"tos.data_usage":"Pomelli'ye y\u00fckledi\u011finiz veya Pomelli'de \u00fcretti\u011finiz veriler incelenebilir ve Google AI'\u0131 daha iyi hale getirmek i\u00e7in kullan\u0131labilir.","tos.manage_settings":"E\u011fitim ayarlar\u0131n\u0131z\u0131 d\u00fczenleyin.","tos.and":"ve","button.agree":"Kabul et ve devam","button.exit":"\u00c7\u0131k","privacy.title":"Pomelli Gizlilik Uyar\u0131s\u0131","privacy.intro":"Bu uyar\u0131 ve","privacy.policy_link":"Gizlilik Politikam\u0131za","privacy.intro_end":"verilerinizin Pomelli taraf\u0131ndan nas\u0131l i\u015flendi\u011fi hakk\u0131nda bilgi verir. L\u00fctfen dikkatle okuyun.",
"privacy.collection":"Pomelli'yi kulland\u0131\u011f\u0131n\u0131zda Google, i\u015fletmenizle ilgili temel verileri (\u00f6r. logonuz, marka renkleriniz, tipografiniz, g\u00f6rselleriniz), kampanya verilerinizi (\u00f6r. istemleriniz ve \u00fcretti\u011finiz i\u00e7erikler), \u00f6zellik kullan\u0131m\u0131n\u0131zla ilgili bilgileri ve geri bildirimlerinizi toplar. Google; Google \u00fcr\u00fcnlerini, hizmetlerini ve \u00fcretken yapay zeka modellerini sa\u011flamak, daha iyi hale getirmek ve geli\u015ftirmek i\u00e7in bu verileri",
"privacy.collection_end":"ve sizin Pomelli ayarlar\u0131n\u0131za uygun \u015fekilde kullan\u0131r. Kullan\u0131c\u0131 verilerinizin silinmesini talep etmek i\u00e7in pomelli-help@google.com adresine e-posta g\u00f6ndererek bize ula\u015fabilirsiniz.","privacy.protection":"Gizlili\u011finizi korumak i\u00e7in gerekli \u00f6nlemleri al\u0131yoruz. Modellerimizi daha iyi hale getirmemize yard\u0131mc\u0131 olmas\u0131 i\u00e7in Pomelli verilerinden rastgele se\u00e7ilen \u00f6rnekler, servis sa\u011flay\u0131c\u0131lar\u0131m\u0131z\u0131n e\u011fitimli uzmanlar\u0131 da dahil olmak \u00fczere uzmanlar\u0131 taraf\u0131ndan incelenebilir. \u00d6rneklere dahil edilen verilerinizin Google Hesab\u0131n\u0131zla ili\u015fkisi kesilir ve bu verilerin sizinle ba\u011flant\u0131l\u0131 oldu\u011fu tespit edilemez. Verileri silmeniz veya daha sonra bu ayar\u0131 devre d\u0131\u015f\u0131 b\u0131rakman\u0131z durumunda dahi Google, kimli\u011fi gizlenen bu \u00f6rnekleri ve ilgili verileri \u00fc\u00e7 y\u0131la kadar saklar. L\u00fctfen bir uzman\u0131n g\u00f6rmesini veya Google'\u0131n Google AI'\u0131 daha iyi hale getirmek i\u00e7in kullanmas\u0131n\u0131 istemeyece\u011finiz gizli bilgiler girmeyin.",
"privacy.control":"Kontrol size aittir. Gelecekte \u00fcretece\u011finiz Pomelli i\u00e7eriklerinizin (\u00f6r. i\u015fletmenizle ilgili temel veriler veya kampanya verileri) \u00fcretken yapay zeka modellerimizin e\u011fitilmesinde kullan\u0131lmas\u0131n\u0131 istemiyorsan\u0131z diledi\u011finiz zaman Pomelli ayarlar\u0131n\u0131z\u0131 d\u00fczenleyerek kapsam d\u0131\u015f\u0131nda kalmay\u0131 se\u00e7ebilirsiniz.","privacy.terms_notice":"Pomelli ayarlar\u0131n\u0131z, hizmetin sa\u011flanmas\u0131 ve sahtekarl\u0131k, k\u00f6t\u00fcye kullan\u0131m ve",
"privacy.google_tos":"Google Hizmet \u015eartlar\u0131","privacy.prohibited_policy":"Yasaklanan Kullan\u0131m Politikas\u0131","privacy.terms_notice_tail":"ihlallerinin daha iyi tespit edilebilmesi ve bunlara m\u00fcdahale edilebilmesi i\u00e7in verilerinizin i\u015flenmesini kapsamaz.","privacy.last_updated":"Son g\u00fcncelleme: 11.06.2025","settings.title":"Hesap Ayarlar\u0131","settings.subtitle":"Hesap ayarlar\u0131n\u0131z\u0131 g\u00f6r\u00fcnt\u00fcleyin ve d\u00fczenleyin","settings.help_title":"Pomelli'nin herkes i\u00e7in daha iyi hale getirilmesine yard\u0131mc\u0131 olun",
"settings.help_on":"\u0130\u015fletmenizle ilgili temel veriler ve kampanya verileriniz dahil olmak \u00fczere verilerinizin Google'\u0131n \u00fcretken yapay zeka modellerinin e\u011fitilmesinde kullan\u0131lmas\u0131na izin vererek Pomelli'nin hem sizin i\u00e7in hem de t\u00fcm kullan\u0131c\u0131lar i\u00e7in daha iyi hale getirilmesine yard\u0131mc\u0131 olabilirsiniz. Gizlili\u011finizi korumak i\u00e7in gerekli \u00f6nlemleri al\u0131yoruz.","settings.learn_more":"Daha fazla bilgi edinin",
"settings.help_on_tail":"Bu ayar devre d\u0131\u015f\u0131 b\u0131rak\u0131lsa bile sahtekarl\u0131k, k\u00f6t\u00fcye kullan\u0131m ve","settings.help_off":"Gelecekte olu\u015facak verileriniz, geri bildirimde bulundu\u011funuz durumlar haricinde, Google'\u0131n \u00fcretken yapay zeka modellerinin daha iyi hale getirilmesi i\u00e7in kullan\u0131lmayacakt\u0131r. Kimli\u011fi gizlenmi\u015f ve daha \u00f6nce uzmanlar taraf\u0131ndan incelenmi\u015f veriler, silinse bile \u00fc\u00e7 y\u0131la kadar saklan\u0131r.",
"settings.help_off_tail":"Bu ayar devre d\u0131\u015f\u0131 b\u0131rak\u0131lsa bile sahtekarl\u0131k, k\u00f6t\u00fcye kullan\u0131m ve",disclaimer:"Pomelli hata yapabilir. \u00dcretilen i\u00e7erikleri kontrol edin.",sample_businesses:"Bunlar, yapay zeka taraf\u0131ndan kurgusal bir isim verilerek \u00fcretilmi\u015f i\u015fletmelerdir. \u0130\u00e7eriklerin do\u011fru veya yasal olup olmad\u0131\u011f\u0131n\u0131 kontrol etmek sizin sorumlulu\u011funuzdad\u0131r.","marketing.title":"Ba\u011flant\u0131da kal\u0131n",
"marketing.subtitle":"A\u015fa\u011f\u0131daki se\u00e7enekleri tercih ederek deneyiminizi daha iyi hale getirebilme konusunda bize yard\u0131mc\u0131 olabilirsiniz:","marketing.email_optin":"Pornelli hakk\u0131ndaki g\u00fcncellemeler, teklifler, faydal\u0131 ipu\u00e7lar\u0131 ve haberler hakk\u0131nda e-posta almak istiyorum","marketing.uxr_optin":"Pornelli'nin gelecekteki ara\u015ft\u0131rma \u00e7al\u0131\u015fmalar\u0131na kat\u0131lmakla ilgileniyorum","marketing.confirm":"Onayla","marketing.comm_prefs":"\u0130leti\u015fim tercihleri",
"website.publish.rights_disclaimer":"Yay\u0131nlamadan \u00f6nce, bu sitedeki t\u00fcm i\u00e7eriklerle ilgili gerekli haklara sahip oldu\u011funuzdan emin olun","website.publish.replace_live_warning":"Bunu yay\u0131nlad\u0131\u011f\u0131n\u0131zda, yay\u0131ndaki mevcut s\u00fcr\u00fcm\u00fcn yerini al\u0131r. Yay\u0131nlamadan \u00f6nce, bu sitedeki t\u00fcm i\u00e7eriklerle ilgili gerekli haklara sahip oldu\u011funuzdan emin olun.","website.report_legal_issue":"Yasal sorun bildirin","instagram.dialog.legal.prefix":"Instagram'da i\u00e7erik yay\u0131nlad\u0131\u011f\u0131n\u0131zda, y\u00fckledi\u011finiz i\u00e7erikle ilgili gerekli t\u00fcm haklara sahip oldu\u011funuzu onaylam\u0131\u015f olursunuz. Instagram'\u0131n",
"instagram.dialog.legal.terms":"Kullan\u0131m Ko\u015fullar\u0131","instagram.dialog.legal.and":"ve","instagram.dialog.legal.privacy":"Gizlilik \u0130lkesi","instagram.dialog.legal.suffix":"yay\u0131nlad\u0131\u011f\u0131n\u0131z t\u00fcm i\u00e7erikler i\u00e7in ge\u00e7erlidir."},bg:{"url.rights_disclaimer.prefix":"\u041c\u043e\u043b\u044f, \u0443\u0432\u0435\u0440\u0435\u0442\u0435 \u0441\u0435, \u0447\u0435 \u043f\u0440\u0438\u0442\u0435\u0436\u0430\u0432\u0430\u0442\u0435 \u0432\u0441\u0438\u0447\u043a\u0438",
"url.rights_disclaimer.link":"\u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u0438 \u043f\u0440\u0430\u0432\u0430","url.rights_disclaimer.suffix":"\u0437\u0430 \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435\u0442\u043e, \u043a\u043e\u0435\u0442\u043e \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u044f\u0442\u0435.","upload_disclaimer.body.prefix":"\u0418\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u0439\u043a\u0438 \u0442\u0430\u0437\u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u044f, \u043f\u043e\u0442\u0432\u044a\u0440\u0436\u0434\u0430\u0432\u0430\u0442\u0435, \u0447\u0435 \u043f\u0440\u0438\u0442\u0435\u0436\u0430\u0432\u0430\u0442\u0435",
"upload_disclaimer.body.link":"\u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u0438\u0442\u0435 \u043f\u0440\u0430\u0432\u0430","upload_disclaimer.body.middle":"\u0432\u044a\u0440\u0445\u0443 \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435\u0442\u043e, \u043a\u043e\u0435\u0442\u043e \u043a\u0430\u0447\u0432\u0430\u0442\u0435. \u041d\u0435 \u0433\u0435\u043d\u0435\u0440\u0438\u0440\u0430\u0439\u0442\u0435 \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435, \u043a\u043e\u0435\u0442\u043e \u043d\u0430\u0440\u0443\u0448\u0430\u0432\u0430 \u043f\u0440\u0430\u0432\u0430\u0442\u0430 \u043d\u0430 \u0438\u043d\u0442\u0435\u043b\u0435\u043a\u0442\u0443\u0430\u043b\u043d\u0430 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043e\u0441\u0442 \u0438\u043b\u0438 \u043f\u0440\u0430\u0432\u0430\u0442\u0430 \u0437\u0430 \u043f\u043e\u0432\u0435\u0440\u0438\u0442\u0435\u043b\u043d\u043e\u0441\u0442 \u043d\u0430 \u0434\u0440\u0443\u0433\u0438 \u043b\u0438\u0446\u0430. \u0418\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u043d\u0435\u0442\u043e \u043d\u0430 \u0442\u0430\u0437\u0438 \u0443\u0441\u043b\u0443\u0433\u0430 \u0437\u0430 \u0433\u0435\u043d\u0435\u0440\u0430\u0442\u0438\u0432\u0435\u043d AI \u043e\u0442 \u0432\u0430\u0448\u0430 \u0441\u0442\u0440\u0430\u043d\u0430 \u0435 \u043f\u0440\u0435\u0434\u043c\u0435\u0442 \u043d\u0430",
"upload_disclaimer.body.policy_link":"\u043f\u0440\u0430\u0432\u0438\u043b\u0430\u0442\u0430 \u043d\u0438 \u043e\u0442\u043d\u043e\u0441\u043d\u043e \u0437\u0430\u0431\u0440\u0430\u043d\u0435\u043d\u043e\u0442\u043e \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u043d\u0435","upload_disclaimer.body.suffix":".",disclaimer:"Pomelli \u043c\u043e\u0436\u0435 \u0434\u0430 \u0434\u043e\u043f\u0443\u0441\u043a\u0430 \u0433\u0440\u0435\u0448\u043a\u0438, \u043f\u043e\u0440\u0430\u0434\u0438 \u043a\u043e\u0435\u0442\u043e \u043f\u0440\u043e\u0432\u0435\u0440\u044f\u0432\u0430\u0439\u0442\u0435 \u043f\u043e\u0432\u0442\u043e\u0440\u043d\u043e.",
"disclaimer.professional":"\u0413\u0435\u043d\u0435\u0440\u0438\u0440\u0430\u043d\u0438\u0442\u0435 \u0440\u0435\u0437\u0443\u043b\u0442\u0430\u0442\u0438 \u0441\u043b\u0435\u0434\u0432\u0430 \u0434\u0430 \u0441\u0435 \u043f\u043e\u043b\u0437\u0432\u0430\u0442 \u0441\u0430\u043c\u043e \u043a\u0430\u0442\u043e \u043d\u0430\u0441\u043e\u043a\u0438 \u0438 \u043d\u0435 \u0437\u0430\u043c\u0435\u043d\u044f\u0442 \u043f\u0440\u043e\u0444\u0435\u0441\u0438\u043e\u043d\u0430\u043b\u043d\u0438\u0442\u0435 \u043f\u0440\u0430\u0432\u043d\u0438, \u043c\u0430\u0440\u043a\u0435\u0442\u0438\u043d\u0433\u043e\u0432\u0438 \u0438\u043b\u0438 \u0431\u0438\u0437\u043d\u0435\u0441 \u0441\u044a\u0432\u0435\u0442\u0438.",
sample_businesses:"\u0422\u043e\u0432\u0430 \u0441\u0430 \u0441\u044a\u0437\u0434\u0430\u0434\u0435\u043d\u0438 \u043e\u0442 \u0438\u0437\u043a\u0443\u0441\u0442\u0432\u0435\u043d \u0438\u043d\u0442\u0435\u043b\u0435\u043a\u0442 \u043f\u0440\u0438\u043c\u0435\u0440\u043d\u0438 \u0431\u0438\u0437\u043d\u0435\u0441\u0438 \u0438 \u0442\u0435\u0445\u043d\u0438\u0442\u0435 \u0438\u043c\u0435\u043d\u0430 \u0441\u0430 \u0438\u0437\u043c\u0438\u0441\u043b\u0435\u043d\u0438 \u0438 \u043e\u0442 \u043e\u0431\u0449 \u0445\u0430\u0440\u0430\u043a\u0442\u0435\u0440. \u0412\u0430\u0448\u0430 \u0435 \u043e\u0442\u0433\u043e\u0432\u043e\u0440\u043d\u043e\u0441\u0442\u0442\u0430 \u0434\u0430 \u0441\u0435 \u0443\u0432\u0435\u0440\u0438\u0442\u0435, \u0447\u0435 \u0432\u0441\u044f\u043a\u0430\u043a\u0432\u0438 \u0444\u0438\u043d\u0430\u043b\u043d\u0438 \u0440\u0435\u0437\u0443\u043b\u0442\u0430\u0442\u0438 \u0441\u0430 \u0442\u043e\u0447\u043d\u0438 \u0438 \u0441\u044a\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0430\u0442 \u043d\u0430 \u0437\u0430\u043a\u043e\u043d\u0430.",
"settings.help_title":"\u041f\u043e\u043c\u043e\u0433\u043d\u0435\u0442\u0435 \u0437\u0430 \u043f\u043e\u0434\u043e\u0431\u0440\u044f\u0432\u0430\u043d\u0435\u0442\u043e \u043d\u0430 Pomelli \u0437\u0430 \u0432\u0441\u0438\u0447\u043a\u0438","settings.help_on":"\u041f\u043e\u0437\u0432\u043e\u043b\u0435\u0442\u0435 \u0434\u0430\u043d\u043d\u0438\u0442\u0435 \u0432\u0438 (\u0432\u043a\u043b\u044e\u0447\u0438\u0442\u0435\u043b\u043d\u043e \u0434\u0430\u043d\u043d\u0438\u0442\u0435 \u0437\u0430 \u0441\u044a\u0449\u043d\u043e\u0441\u0442\u0442\u0430 \u043d\u0430 \u0431\u0438\u0437\u043d\u0435\u0441\u0430 \u0432\u0438 \u0438 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438\u0442\u0435 \u0432\u0438) \u0434\u0430 \u0441\u0435 \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u0442 \u0437\u0430 \u043e\u0431\u0443\u0447\u0430\u0432\u0430\u043d\u0435 \u043d\u0430 \u043c\u043e\u0434\u0435\u043b\u0438\u0442\u0435 \u0437\u0430 \u0433\u0435\u043d\u0435\u0440\u0430\u0442\u0438\u0432\u0435\u043d AI \u043d\u0430 Google, \u043a\u043e\u0435\u0442\u043e \u0449\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u0438 Pomelli \u043f\u043e-\u0434\u043e\u0431\u044a\u0440 \u043f\u0440\u043e\u0434\u0443\u043a\u0442 \u0437\u0430 \u0432\u0430\u0441 \u0438 \u0432\u0441\u0435\u043a\u0438, \u043a\u043e\u0439\u0442\u043e \u0433\u043e \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430. \u041f\u0440\u0438\u043b\u0430\u0433\u0430\u043c\u0435 \u0441\u0442\u044a\u043f\u043a\u0438 \u0437\u0430 \u0437\u0430\u0449\u0438\u0442\u0430 \u043d\u0430 \u043f\u043e\u0432\u0435\u0440\u0438\u0442\u0435\u043b\u043d\u043e\u0441\u0442\u0442\u0430 \u0432\u0438.",
"settings.learn_more":"\u041d\u0430\u0443\u0447\u0435\u0442\u0435 \u043f\u043e\u0432\u0435\u0447\u0435","settings.help_on_tail":"\u041a\u043e\u0433\u0430\u0442\u043e \u0442\u0430\u0437\u0438 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0430 \u0435 \u0438\u0437\u043a\u043b\u044e\u0447\u0435\u043d\u0430, \u0434\u0430\u043d\u043d\u0438\u0442\u0435 \u0432\u0438 \u0432\u0441\u0435 \u043f\u0430\u043a \u043c\u043e\u0433\u0430\u0442 \u0434\u0430 \u0431\u044a\u0434\u0430\u0442 \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u043d\u0438 \u0437\u0430 \u043f\u043e-\u0434\u043e\u0431\u0440\u043e \u0440\u0430\u0437\u043f\u043e\u0437\u043d\u0430\u0432\u0430\u043d\u0435 \u0438 \u0440\u0435\u0430\u043a\u0446\u0438\u044f \u043d\u0430 \u0438\u0437\u043c\u0430\u043c\u0438, \u0437\u043b\u043e\u0443\u043f\u043e\u0442\u0440\u0435\u0431\u0438 \u0438 \u043d\u0430\u0440\u0443\u0448\u0435\u043d\u0438\u044f \u043d\u0430",
"settings.help_off":"\u0411\u044a\u0434\u0435\u0449\u0438\u0442\u0435 \u0432\u0438 \u0434\u0430\u043d\u043d\u0438 \u043d\u044f\u043c\u0430 \u0434\u0430 \u0441\u0435 \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u0442 \u0437\u0430 \u043f\u043e\u0434\u043e\u0431\u0440\u044f\u0432\u0430\u043d\u0435 \u043d\u0430 \u043c\u043e\u0434\u0435\u043b\u0438\u0442\u0435 \u0437\u0430 \u0433\u0435\u043d\u0435\u0440\u0430\u0442\u0438\u0432\u0435\u043d AI \u043d\u0430 Google, \u043e\u0441\u0432\u0435\u043d \u0430\u043a\u043e \u043d\u0435 \u0438\u0437\u043f\u0440\u0430\u0442\u0438\u0442\u0435 \u043e\u0442\u0437\u0438\u0432\u0438. \u0414\u0435\u0438\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u0446\u0438\u0440\u0430\u043d\u0438 \u0438\u0437\u0432\u0430\u0434\u043a\u0438, \u043a\u043e\u0438\u0442\u043e \u0432\u0435\u0447\u0435 \u0441\u0430 \u0431\u0438\u043b\u0438 \u043f\u0440\u0435\u0433\u043b\u0435\u0434\u0430\u043d\u0438 \u043e\u0442 \u043f\u0440\u043e\u0432\u0435\u0440\u044f\u0432\u0430\u0449\u0438 \u043b\u0438\u0446\u0430, \u0441\u0435 \u0437\u0430\u043f\u0430\u0437\u0432\u0430\u0442 \u0437\u0430 \u043f\u0435\u0440\u0438\u043e\u0434 \u0434\u043e \u0442\u0440\u0438 \u0433\u043e\u0434\u0438\u043d\u0438 \u0434\u043e\u0440\u0438 \u0430\u043a\u043e \u0433\u0438 \u0438\u0437\u0442\u0440\u0438\u0435\u0442\u0435.",
"settings.help_off_tail":"\u041a\u043e\u0433\u0430\u0442\u043e \u0442\u0430\u0437\u0438 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0430 \u0435 \u0438\u0437\u043a\u043b\u044e\u0447\u0435\u043d\u0430, \u0434\u0430\u043d\u043d\u0438\u0442\u0435 \u0432\u0438 \u0432\u0441\u0435 \u043f\u0430\u043a \u043c\u043e\u0433\u0430\u0442 \u0434\u0430 \u0431\u044a\u0434\u0430\u0442 \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u043d\u0438 \u0437\u0430 \u043f\u043e-\u0434\u043e\u0431\u0440\u043e \u0440\u0430\u0437\u043f\u043e\u0437\u043d\u0430\u0432\u0430\u043d\u0435 \u0438 \u0440\u0435\u0430\u043a\u0446\u0438\u044f \u043d\u0430 \u0438\u0437\u043c\u0430\u043c\u0438, \u0437\u043b\u043e\u0443\u043f\u043e\u0442\u0440\u0435\u0431\u0438 \u0438 \u043d\u0430\u0440\u0443\u0448\u0435\u043d\u0438\u044f \u043d\u0430",
