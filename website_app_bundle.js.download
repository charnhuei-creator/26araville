"website.report_legal_issue":"Prijavite pravno te\u017eavo","instagram.dialog.legal.prefix":"Z objavo vsebine v Instagramu potrjujete, da imate vse potrebne pravice za vsebino, ki jo nalo\u017eite. Za vso vsebino, ki jo objavite, veljajo Instagramovi","instagram.dialog.legal.terms":"pogoji","instagram.dialog.legal.and":"in","instagram.dialog.legal.privacy":"pravilnik o zasebnosti","instagram.dialog.legal.suffix":"."}};
