"marketing.uxr_optin":"\u0418\u043d\u0442\u0435\u0440\u0435\u0441\u0443\u0432\u0430\u043c \u0441\u0435 \u043e\u0442 \u043f\u043e\u043a\u0430\u043d\u0430 \u0437\u0430 \u0431\u044a\u0434\u0435\u0449\u0438 \u0438\u0437\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u0441\u043a\u0438 \u043f\u0440\u043e\u0443\u0447\u0432\u0430\u043d\u0438\u044f \u043e\u0442 Pomelli","website.publish.rights_disclaimer":"\u041f\u0440\u0435\u0434\u0438 \u0434\u0430 \u043f\u0443\u0431\u043b\u0438\u043a\u0443\u0432\u0430\u0442\u0435, \u043f\u0440\u043e\u0432\u0435\u0440\u0435\u0442\u0435 \u0434\u0430\u043b\u0438 \u0438\u043c\u0430\u0442\u0435 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u0438\u0442\u0435 \u043f\u0440\u0430\u0432\u0430 \u0437\u0430 \u0446\u044f\u043b\u043e\u0442\u043e \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435, \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u0435\u043d\u043e \u043d\u0430 \u0442\u043e\u0437\u0438 \u0441\u0430\u0439\u0442.",
"website.publish.replace_live_warning":"\u041f\u0443\u0431\u043b\u0438\u043a\u0443\u0432\u0430\u043d\u0435\u0442\u043e \u043d\u0430 \u0442\u043e\u0432\u0430 \u0449\u0435 \u0437\u0430\u043c\u0435\u043d\u0438 \u0442\u0435\u043a\u0443\u0449\u0430\u0442\u0430 \u0430\u043a\u0442\u0438\u0432\u043d\u0430 \u0432\u0435\u0440\u0441\u0438\u044f. \u041f\u0440\u0435\u0434\u0438 \u0434\u0430 \u043f\u0443\u0431\u043b\u0438\u043a\u0443\u0432\u0430\u0442\u0435, \u043f\u0440\u043e\u0432\u0435\u0440\u0435\u0442\u0435 \u0434\u0430\u043b\u0438 \u0438\u043c\u0430\u0442\u0435 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u0438\u0442\u0435 \u043f\u0440\u0430\u0432\u0430 \u0437\u0430 \u0446\u044f\u043b\u043e\u0442\u043e \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435, \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u0435\u043d\u043e \u043d\u0430 \u0442\u043e\u0437\u0438 \u0441\u0430\u0439\u0442.",
"website.report_legal_issue":"\u0421\u044a\u043e\u0431\u0449\u0435\u0442\u0435 \u0437\u0430 \u043f\u0440\u0430\u0432\u0435\u043d \u043f\u0440\u043e\u0431\u043b\u0435\u043c","instagram.dialog.legal.prefix":"\u0421 \u043f\u0443\u0431\u043b\u0438\u043a\u0443\u0432\u0430\u043d\u0435\u0442\u043e \u043d\u0430 \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435 \u0432 Instagram, \u0432\u0438\u0435 \u043f\u043e\u0442\u0432\u044a\u0440\u0436\u0434\u0430\u0432\u0430\u0442\u0435, \u0447\u0435 \u0438\u043c\u0430\u0442\u0435 \u0432\u0441\u0438\u0447\u043a\u0438 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u0438 \u043f\u0440\u0430\u0432\u0430 \u0437\u0430 \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435\u0442\u043e, \u043a\u043e\u0435\u0442\u043e \u043a\u0430\u0447\u0432\u0430\u0442\u0435.",
"instagram.dialog.legal.terms":"\u0423\u0441\u043b\u043e\u0432\u0438\u044f\u0442\u0430","instagram.dialog.legal.and":"\u0438","instagram.dialog.legal.privacy":"\u041f\u043e\u043b\u0438\u0442\u0438\u043a\u0430\u0442\u0430 \u0437\u0430 \u043f\u043e\u0432\u0435\u0440\u0438\u0442\u0435\u043b\u043d\u043e\u0441\u0442","instagram.dialog.legal.suffix":"\u043d\u0430 Instagram \u0441\u0435 \u043f\u0440\u0438\u043b\u0430\u0433\u0430\u0442 \u0437\u0430 \u0432\u0441\u044f\u043a\u043e \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435, \u043a\u043e\u0435\u0442\u043e \u043f\u0443\u0431\u043b\u0438\u043a\u0443\u0432\u0430\u0442\u0435."},
cs:{"url.rights_disclaimer.prefix":"Ujist\u011bte se, \u017ee m\u00e1te ve\u0161ker\u00e1","url.rights_disclaimer.link":"pot\u0159ebn\u00e1 pr\u00e1va","url.rights_disclaimer.suffix":"k obsahu, kter\u00fd poskytujete.","upload_disclaimer.body.prefix":"Pou\u017e\u00edv\u00e1n\u00edm t\u00e9to funkce potvrzujete, \u017ee m\u00e1te","upload_disclaimer.body.link":"pot\u0159ebn\u00e1 pr\u00e1va","upload_disclaimer.body.middle":"k obsahu, kter\u00fd nahrajete. Nevytv\u00e1\u0159ejte obsah, kter\u00fd poru\u0161uje autorsk\u00e1 pr\u00e1va nebo soukrom\u00ed jin\u00fdch osob. Va\u0161e pou\u017e\u00edv\u00e1n\u00ed t\u00e9to generativn\u00ed slu\u017eby AI podl\u00e9h\u00e1 na\u0161im",
"upload_disclaimer.body.policy_link":"z\u00e1sad\u00e1m zak\u00e1zan\u00e9ho pou\u017e\u00edv\u00e1n\u00ed","upload_disclaimer.body.suffix":".",disclaimer:"Pomelli m\u016f\u017ee ud\u011blat chybu, proto v\u00fdsledky pe\u010dliv\u011b kontrolujte.","disclaimer.professional":"Vytvo\u0159en\u00e9 v\u00fdstupy slou\u017e\u00ed pouze jako vod\u00edtko a nenahrazuj\u00ed odborn\u00e9 pr\u00e1vn\u00ed, marketingov\u00e9 nebo obchodn\u00ed poradenstv\u00ed.",sample_businesses:"Jedn\u00e1 se o vzorov\u00e9 firmy generovan\u00e9 um\u011blou inteligenc\u00ed s obecn\u00fdmi fiktivn\u00edmi n\u00e1zvy firem. Za ov\u011b\u0159en\u00ed spr\u00e1vnosti a leg\u00e1lnosti v\u0161ech kone\u010dn\u00fdch v\u00fdstup\u016f jste zodpov\u011bdn\u00ed vy.",
"settings.help_title":"Pomozte zlep\u0161it Pomelli pro v\u0161echny","settings.help_on":"Povolte pou\u017eit\u00ed va\u0161ich dat (v\u010detn\u011b va\u0161\u00ed firemn\u00ed DNA a dat z kampan\u00ed) k tr\u00e9nov\u00e1n\u00ed generativn\u00edch model\u016f um\u011bl\u00e9 inteligence spole\u010dnosti Google, d\u00edky \u010demu\u017e bude Pomelli lep\u0161\u00ed pro v\u00e1s i pro v\u0161echny, kdo ho pou\u017e\u00edvaj\u00ed. Z\u00e1le\u017e\u00ed n\u00e1m na ochran\u011b va\u0161eho soukrom\u00ed.",
