</style><script>
(function() {
  var selector = "img[src*=\"aTksN2R2QSM4i5G-7f9k53\"],[style*=\"aTksN2R2QSM4i5G-7f9k53\"]";
  if (!selector) return;
  const targets = document.querySelectorAll(selector);
  if (!targets.length) return;

  const pairs = [];
  targets.forEach(function(target) {
    const badge = document.createElement('div');
    badge.className = 'ai-image-badge';
    document.body.appendChild(badge);
    pairs.push({ target: target, badge: badge });
  });

  function position() {
    const bodyRect = document.body.getBoundingClientRect();
    const bodyTop = bodyRect.top + document.body.clientTop;
    const bodyLeft = bodyRect.left + document.body.clientLeft;
    pairs.forEach(function({target, badge}) {
      const rect = target.getBoundingClientRect();
      badge.style.top = (rect.bottom - bodyTop - 25 - 8) + 'px';
      badge.style.left = (rect.right - bodyLeft - 25 - 8) + 'px';
    });
  }

  new ResizeObserver(position).observe(document.body);
  position();
})();
